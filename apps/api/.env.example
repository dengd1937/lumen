# DashScope (Qwen-Max + text-embedding-v3) — per ADR-0001 D6
DASHSCOPE_API_KEY=

# LLM provider switch — per ADR-0001 D6 fallback strategy
# values: qwen-max | qwen-plus | claude
LLM_PROVIDER=qwen-max

# Firecrawl (web retriever)
FIRECRAWL_API_KEY=

# LangSmith observability
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=lumen
LANGSMITH_TRACING=true

# Local data paths — per ADR-0001 D5
LUMEN_DATA_DIR=./data
LUMEN_DB_PATH=./data/lumen.db
LUMEN_CHROMA_PATH=./data/chroma
