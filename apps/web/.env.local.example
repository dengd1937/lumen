# Lumen 前端环境变量模板
#
# 实际使用：
#   cp .env.local.example .env.local
#   编辑 .env.local 填入真实值

# 数据通道：mock | sse
# - mock：消费 src/lib/*-mock.ts，不依赖后端进程（默认）
# - sse：通过 /api/* rewrite 走 FastAPI（要求 apps/api 进程运行在 :8000）
NEXT_PUBLIC_LUMEN_DATA_SOURCE=mock

# 后端 API 代理地址（next.config.ts rewrite 目标）
# - 默认 http://localhost:8000，开发环境通常无需修改
# - 生产环境必须显式设置为后端可达地址，否则会代理到 localhost 失败
LUMEN_API_PROXY_TARGET=http://localhost:8000
