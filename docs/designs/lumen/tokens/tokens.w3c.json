{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Lumen design tokens (V2-3). Source of truth for tokens.css / tokens.ts / tailwind-preset.ts. Exported from docs/designs/lumen/design.pen.",
  "color": {
    "bg": {
      "$type": "color",
      "$value": "#0A0A0B",
      "$extensions": { "themed": { "dark": "#0A0A0B", "light": "#FAFAFA" } }
    },
    "surface": {
      "$type": "color",
      "$value": "#18181B",
      "$extensions": { "themed": { "dark": "#18181B", "light": "#FFFFFF" } }
    },
    "surface-elevated": {
      "$type": "color",
      "$value": "#27272A",
      "$extensions": { "themed": { "dark": "#27272A", "light": "#F4F4F5" } }
    },
    "border": {
      "$type": "color",
      "$value": "#27272A",
      "$extensions": { "themed": { "dark": "#27272A", "light": "#E4E4E7" } }
    },
    "border-subtle": {
      "$type": "color",
      "$value": "#1F1F23",
      "$extensions": { "themed": { "dark": "#1F1F23", "light": "#F4F4F5" } }
    },
    "fg": {
      "$type": "color",
      "$value": "#FAFAFA",
      "$extensions": { "themed": { "dark": "#FAFAFA", "light": "#18181B" } }
    },
    "fg-muted": {
      "$type": "color",
      "$value": "#A1A1AA",
      "$extensions": { "themed": { "dark": "#A1A1AA", "light": "#52525B" } }
    },
    "fg-subtle": {
      "$type": "color",
      "$value": "#71717A",
      "$extensions": { "themed": { "dark": "#71717A", "light": "#A1A1AA" } }
    },
    "ring": {
      "$type": "color",
      "$value": "#E4E4E7",
      "$extensions": { "themed": { "dark": "#E4E4E7", "light": "#18181B" } }
    },
    "primary": { "$type": "color", "$value": "#1E40AF" },
    "primary-fg": { "$type": "color", "$value": "#FFFFFF" },
    "primary-hover": { "$type": "color", "$value": "#1E3A8A" },
    "track-web-fg": {
      "$type": "color",
      "$value": "#0EA5E9",
      "$extensions": { "themed": { "dark": "#0EA5E9", "light": "#0369A1" } }
    },
    "track-web-bg": { "$type": "color", "$value": "#0EA5E91A" },
    "track-web-border": { "$type": "color", "$value": "#0EA5E9" },
    "track-web-muted": { "$type": "color", "$value": "#0369A1" },
    "track-web-glow": { "$type": "color", "$value": "#0EA5E966" },
    "track-kb-fg": {
      "$type": "color",
      "$value": "#A78BFA",
      "$extensions": { "themed": { "dark": "#A78BFA", "light": "#6D28D9" } }
    },
    "track-kb-bg": { "$type": "color", "$value": "#8B5CF61A" },
    "track-kb-border": { "$type": "color", "$value": "#8B5CF6" },
    "track-kb-muted": { "$type": "color", "$value": "#6D28D9" },
    "track-kb-glow": { "$type": "color", "$value": "#8B5CF666" },
    "node-state-planning": { "$type": "color", "$value": "#3B82F6" },
    "node-state-retrieving": { "$type": "color", "$value": "#F59E0B" },
    "node-state-completed": { "$type": "color", "$value": "#10B981" },
    "node-state-error": { "$type": "color", "$value": "#EF4444" },
    "conflict-fg": {
      "$type": "color",
      "$value": "#FF8400",
      "$extensions": { "themed": { "dark": "#FF8400", "light": "#C2570A" } }
    },
    "conflict-bg": { "$type": "color", "$value": "#FF84001F" },
    "conflict-border": { "$type": "color", "$value": "#FF8400" },
    "conflict-glow": { "$type": "color", "$value": "#FF840055" },
    "citation-badge": { "$type": "color", "$value": "#1E40AF" },
    "citation-highlight": {
      "$type": "color",
      "$value": "#FDE68A",
      "$extensions": { "themed": { "dark": "#FDE68A", "light": "#FEF3C7" } }
    },
    "shadow-color": {
      "$type": "color",
      "$value": "#00000066",
      "$extensions": { "themed": { "dark": "#00000066", "light": "#0000001F" } }
    }
  },
  "space": {
    "0":   { "$type": "dimension", "$value": "0px" },
    "0_5": { "$type": "dimension", "$value": "2px" },
    "1":   { "$type": "dimension", "$value": "4px" },
    "1_5": { "$type": "dimension", "$value": "6px" },
    "2":   { "$type": "dimension", "$value": "8px" },
    "2_5": { "$type": "dimension", "$value": "10px" },
    "3":   { "$type": "dimension", "$value": "12px" },
    "3_5": { "$type": "dimension", "$value": "14px" },
    "4":   { "$type": "dimension", "$value": "16px" },
    "5":   { "$type": "dimension", "$value": "20px" },
    "6":   { "$type": "dimension", "$value": "24px" },
    "8":   { "$type": "dimension", "$value": "32px" },
    "10":  { "$type": "dimension", "$value": "40px" },
    "12":  { "$type": "dimension", "$value": "48px" },
    "16":  { "$type": "dimension", "$value": "64px" },
    "20":  { "$type": "dimension", "$value": "80px" }
  },
  "radius": {
    "xs":   { "$type": "dimension", "$value": "2px" },
    "sm":   { "$type": "dimension", "$value": "4px" },
    "md":   { "$type": "dimension", "$value": "8px" },
    "lg":   { "$type": "dimension", "$value": "24px" },
    "xl":   { "$type": "dimension", "$value": "32px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "font-size": {
    "xs":   { "$type": "dimension", "$value": "12px" },
    "sm":   { "$type": "dimension", "$value": "13px" },
    "base": { "$type": "dimension", "$value": "14px" },
    "md":   { "$type": "dimension", "$value": "16px" },
    "lg":   { "$type": "dimension", "$value": "18px" },
    "xl":   { "$type": "dimension", "$value": "20px" },
    "2xl":  { "$type": "dimension", "$value": "24px" },
    "3xl":  { "$type": "dimension", "$value": "32px" },
    "4xl":  { "$type": "dimension", "$value": "40px" }
  },
  "line-height": {
    "tight":  { "$type": "number", "$value": 1.2 },
    "normal": { "$type": "number", "$value": 1.5 },
    "loose":  { "$type": "number", "$value": 1.75 }
  },
  "font-family": {
    "sans": { "$type": "fontFamily", "$value": ["Geist", "ui-sans-serif", "system-ui", "sans-serif"] },
    "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "SFMono-Regular", "monospace"] }
  },
  "duration": {
    "fast": { "$type": "duration", "$value": "150ms" },
    "base": { "$type": "duration", "$value": "240ms" },
    "slow": { "$type": "duration", "$value": "360ms" }
  },
  "easing": {
    "out":    { "$type": "cubicBezier", "$value": [0.16, 1, 0.3, 1] },
    "in-out": { "$type": "cubicBezier", "$value": [0.65, 0, 0.35, 1] }
  },
  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px", "color": "{color.shadow-color}" }
    },
    "md": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "4px", "blur": "12px", "spread": "0px", "color": "{color.shadow-color}" }
    },
    "lg": {
      "$type": "shadow",
      "$value": { "offsetX": "0px", "offsetY": "12px", "blur": "32px", "spread": "0px", "color": "{color.shadow-color}" }
    }
  },
  "z-index": {
    "base":    { "$type": "number", "$value": 0 },
    "drawer":  { "$type": "number", "$value": 40 },
    "modal":   { "$type": "number", "$value": 50 },
    "tooltip": { "$type": "number", "$value": 60 }
  }
}
